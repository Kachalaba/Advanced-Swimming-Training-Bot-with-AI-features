# SPRINT AI local configuration.
# Copy to `.env` for local development. Keep real secrets out of git.

# AI coaching providers. The app works in offline/rule-based mode when unset.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Claude model for AI coaching/chat (optional, defaults to claude-sonnet-5).
SPRINT_AI_CLAUDE_MODEL="claude-sonnet-5"

# Shared athlete database settings.
# Streamlit legacy path defaults to data/athletes.db.
# SQLAlchemy ORM path defaults to data/athletes_orm.db.
ATHLETE_DB_PATH="data/athletes_orm.db"

# FastAPI backend.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
MAX_VIDEO_UPLOAD_MB="512"
# TTL (hours) for finished analysis jobs and their temp workspaces.
SPRINT_AI_JOB_TTL_HOURS="24"

# Next.js frontend.
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# Optional error reporting.
SENTRY_DSN=""

# Streamlit Docker image.
PORT="8443"
